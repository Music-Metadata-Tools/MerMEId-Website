@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix melod: <https://lod.academy/melod/vocab/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schema: <https://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mus: <http://data.doremus.org/ontology#> .
@prefix terms: <https://mermeid-data-model-efbf77.pages.gitlab.rlp.net/> .
@prefix melodTerms: <https://lod.academy/melod/vocab/terms#> .

melod:InstrumentationDetail
  a               sh:NodeShape ;
  owl:imports     terms:melod-terms.ttl ;
  sh:property   [ sh:maxCount     1 ;
                  sh:minCount     1 ;
                  sh:name         "Medium of performance" ;
                  sh:or (
                    [ sh:class melodTerms:Brass ; rdfs:label "Brass" ]
                    [ sh:class melodTerms:Electronic ; rdfs:label "Electronic" ]
                    [ sh:class melodTerms:Keyboard ; rdfs:label "Keyboard" ]
                    [ sh:class melodTerms:Percussion ; rdfs:label "Percussion" ]
                    [ sh:class melodTerms:BowedStrings ; rdfs:label "Strings, bowed" ]
                    [ sh:class melodTerms:PluckedStrings ; rdfs:label "Strings, plucked" ]
                    [ sh:class melodTerms:Voices ; rdfs:label "Voices" ]
                    [ sh:class melodTerms:Woodwinds ; rdfs:label "Woodwinds" ]
                    [ sh:class melodTerms:Unspecified ; rdfs:label "Unspecified" ]
                    [ rdfs:label "Custom instrument" ]
                  ) ;
                  sh:path         mus:U2_foresees_use_of_medium_of_performance
                ] ;
  sh:targetClass  melod:InstrumentationDetail .
